  "keyFeatures": [
    "Multi-universe DMX control with Art-Net and sACN support",
    "Comprehensive fixture library with editor",
    "Virtual Console for live show control",
    "Scene, Chaser, and EFX function types",
    "RGB Matrix effects generator",
    "Show Manager for timeline-based shows",
    "2D and 3D visualization",
    "Web-based remote interface",
    "MIDI and OSC input support",
    "Cross-platform (Linux, Windows, macOS, Raspberry Pi)"
  ],
  "publicApiSurface": [
    "Scene - Static lighting state",
    "Chaser - Sequential function runner",
    "EFX - Effect patterns for moving heads",
    "Collection - Parallel function starter",
    "RGB Matrix - Color matrix effects",
    "Script - JavaScript automation",
    "Audio - Audio playback triggers",
    "Video - Video playback",
    "Fixture - Lighting device abstraction",
    "Universe - DMX universe (512 channels)",
    "Virtual Console - Live control interface",
    "Show Manager - Timeline sequencer",
    "Simple Desk - Direct DMX channel control",
    "Input Profile - External controller mapping",
    "Input/Output - Hardware interface configuration",
    "Web Access - HTTP remote control API"
  ]
